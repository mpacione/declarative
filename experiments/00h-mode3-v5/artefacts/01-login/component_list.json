[
  {
    "type": "header",
    "id": "hdr",
    "children": [
      {
        "type": "icon_button",
        "id": "back_btn",
        "props": {
          "icon": "arrow_back"
        }
      },
      {
        "type": "text",
        "id": "title",
        "props": {
          "text": "Login"
        }
      }
    ]
  },
  {
    "type": "card",
    "id": "login_card",
    "children": [
      {
        "type": "heading",
        "id": "login_heading",
        "props": {
          "text": "Welcome Back"
        }
      },
      {
        "type": "text",
        "id": "login_subtitle",
        "props": {
          "text": "Sign in to your account to continue"
        }
      },
      {
        "type": "text_input",
        "id": "email_input",
        "props": {
          "label": "Email",
          "placeholder": "Enter your email"
        }
      },
      {
        "type": "text_input",
        "id": "password_input",
        "props": {
          "label": "Password",
