[
  {
    "type": "header",
    "id": "hdr",
    "children": [
      {
        "type": "icon_button",
        "id": "back",
        "props": {
          "icon": "arrow_back"
        }
      },
      {
        "type": "text",
        "id": "title",
        "props": {
          "text": "Settings"
        }
      }
    ]
  },
  {
    "type": "card",
    "id": "profile_card",
    "children": [
      {
        "type": "heading",
        "id": "profile_heading",
        "props": {
          "text": "Profile"
        }
      },
      {
        "type": "avatar",
        "id": "profile_avatar",
        "props": {
          "size": "large"
        }
      },
      {
        "type": "text_input",
        "id": "name_input",
        "props": {
          "label": "Name",
          "placeholder": "Enter your name"
        }
      },
      {
        "type": "text_input",
        "id": "email_input",
        "props": {
          "label": "Email",
          "placeholder": "Enter your email"
        }
      }
    ]
  },
  {
    "type": "card",
    "id": "notifications_card",
    "children": [
      {
        "type": "heading",
        "id": "notifications_heading",
        "props": {
          "text": "Notifications"
        }
      },
      {
        "type": "list",
        "id": "notification_toggles",
        "children": [
          {
            "type": "navigation_row",
            "id": "toggle_row_1",
            "children": [
              {
                "type": "text",
                "id": "toggle_label_1",
                "props": {
                  "text": "Email Notifications"
                }
              },
              {
                "type": "toggle",
                "id": "toggle_switch_1",
                "props": {
                  "checked": true
                }
              }
            ]
          },
          {
            "type": "navigation_row",
            "id": "toggle_row_2",
            "children": [
              {
                "type": "text",
                "id": "toggle_label_2",
                "props": {
                  "text": "Push Notifications"
                }
              },
              {
                "type": "toggle",
                "id": "toggle_switch_2",
                "props": {
                  "checked": true
                }
              }
            ]
          },
          {
            "type": "navigation_row",
            "id": "toggle_row_3",
            "children": [
              {
                "type": "text",
                "id": "toggle_label_3",
                "props": {
                  "text": "Marketing Emails"
                }
              },
              {
                "type": "toggle",
                "id": "toggle_switch_3",
                "props": {
                  "checked": false
                }
              }
            ]
          },
          {
            "type": "navigation_row",
            "id": "toggle_row_4",
            "children": [
              {
                "type": "text",
                "id": "toggle_label_4",
                "props": {
                  "text": "SMS Alerts"
                }
              },
              {
                "type": "toggle",
                "id": "toggle_switch_4",
                "props": {
                  "checked": false
                }
              }
            ]
          }
        ]
      }
    ]
  },
  {
    "type": "button",
    "id": "save_button",
    "props": {
      "text": "Save Changes",
      "variant": "primary"
    }
  }
]